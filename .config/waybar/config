{
    "layer": "top",
    "position": "top",
    "margin": "8 0 0 0",
    "height": 40,
    "fixed-center": false,
    "spacing": 6,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "custom/powermenu"],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{id}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },
    "clock": {
        "format": "{:%a %d %b - %H:%M}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span font='Font Awesome 5 Free'></span>\u2003\u2003{volume}%",
        "format-muted": "<span font='Font Awesome 5 Free'></span>\u2003\u2003Muted",
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "tooltip": true
    },
    "network": {
        "format": "{icon}",
        "format-wifi": "<span font='Font Awesome 5 Free'></span>\u2003\u2003{essid} ({signalStrength}%)",
        "format-ethernet": "<span font='Font Awesome 5 Free'></span>\u2003\u2003{ifname}",
        "format-disconnected": "<span font='Font Awesome 5 Free'></span>\u2003\u2003Disconnected",
        "tooltip": false
    },
    "custom/powermenu": {
        "return-type": "json",
        "exec": "~/.config/waybar/modules/powermenu.sh",
        "format": "⏻",
        "interval": 3600,
        "escape": true,
        "on-click": "~/.config/rofi/rofi-power.sh"
    }
}
